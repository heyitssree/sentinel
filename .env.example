# Sentinel Trading Platform Configuration
# Copy this file to .env and fill in your values
# See SETUP.md for detailed instructions

# =============================================================================
# Zerodha Kite Connect API
# Get credentials from: https://developers.kite.trade/
# =============================================================================
KITE_API_KEY=your_api_key_here
KITE_API_SECRET=your_api_secret_here
KITE_CLIENT_ID=your_client_id_here
KITE_REDIRECT_URL=http://127.0.0.1:8000/api/zerodha/callback
# Access token expires daily - refresh via OAuth flow
KITE_ACCESS_TOKEN=your_access_token_here

# =============================================================================
# Google Gemini API (for AI Sentiment & Autopsy)
# Get API key from: https://makersuite.google.com/app/apikey
# Requires gemini-2.5-flash model access
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Risk Management - CRITICAL SAFETY SETTINGS
# =============================================================================
# MTM Loss Ceiling (hard-coded safety limit, cannot be overridden by UI)
# Value is a decimal (0.03 = 3% of capital)
MTM_LOSS_CEILING=0.03

# User-configurable MTM limit (can be set lower via UI, never higher than ceiling)
# Default equals ceiling amount; UI allows reducing this
USER_MTM_LIMIT=3000

# Starting capital for percentage calculations
STARTING_CAPITAL=100000

# Risk per trade in INR (used for ATR-based position sizing)
RISK_PER_TRADE=500

# ATR multiplier for stop-loss calculation
ATR_STOP_MULTIPLIER=1.5

# =============================================================================
# Watchdog Settings
# =============================================================================
# Poll interval for independent watchdog (seconds)
WATCHDOG_POLL_INTERVAL=10

# =============================================================================
# News Scraper Settings
# =============================================================================
# Cache TTL for news headlines (seconds)
# Reduces API calls to RSS feeds
NEWS_CACHE_TTL=120

# =============================================================================
# Trading Schedule (IST)
# =============================================================================
# These are defaults - can be overridden in code
OBSERVATION_START=09:15
OBSERVATION_END=09:45
ACTIVE_TRADING_END=14:45
SQUARE_OFF_END=15:15
POST_MARKET_START=15:30

# =============================================================================
# Database
# =============================================================================
DB_PATH=data/sentinel.duckdb

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# Server
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8000
